{
  "name": "x314-dflow-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "check": "bunx tsc --noEmit",
    "test": "DFLOW_API_KEY=test DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/x314 bun test",
    "helius:addresses": "bun src/scripts/export-helius-addresses.ts",
    "db:generate": "bunx drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bunx drizzle-kit migrate --config drizzle.config.ts",
    "db:studio": "bunx drizzle-kit studio --config drizzle.config.ts"
  },
  "dependencies": {
    "bullmq": "^5.58.0",
    "drizzle-orm": "^0.44.5",
    "dotenv": "^16.4.5",
    "elysia": "^1.1.20",
    "ioredis": "^5.5.0",
    "pino": "^9.6.0",
    "pg": "^8.13.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.6.3"
  }
}
